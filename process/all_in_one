STEP 19: STL Containers                                                  [C++]
------------------------------------------------------------------------
  LEARN:
    VECTOR (dynamic array):
      vector<int> v;
      v.push_back(x);   — add to end O(1) amortized
      v.pop_back();     — remove from end O(1)
      v[i]              — access O(1)
      v.size()          — number of elements
      v.empty()         — check if empty
